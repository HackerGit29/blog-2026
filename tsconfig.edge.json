{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": false,
    "strict": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "supabase/functions/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
